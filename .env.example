# 闪联AI周刊 — 环境变量模板
# 用法：复制本文件为 .env 并填入真实值
#   cp .env.example .env
# .env 已被 .gitignore 忽略，不会上传到 GitHub（安全）

# ===== 火山方舟 LLM（生成周报必填）=====
# 端点必须用 coding 端点 /api/coding/v3 + ark-code-latest，用标准 /api/v3 会 401
ARK_API_KEY=你的方舟API_Key
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3
ARK_MODEL=ark-code-latest
ARK_IMAGE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_IMAGE_MODEL=doubao-seedream-4-5-251128

# ===== 邮件发送（send_md_email.py，本地发信用，服务端可不配）=====
# 注意：发件人 SENDER 目前仍硬编码在 send_md_email.py 顶部，改邮箱需编辑该文件
QQ_MAIL_PASSWORD=你的QQ邮箱授权码
QQ_MAIL_RECEIVERS=收件人1@example.com,收件人2@example.com
WEEKLY_SITE_URL=http://你的服务器IP:5000/

# ===== 代理（默认直连；若服务器需经代理访问方舟，取消下面两行注释）=====
# AI_WEEKLY_USE_PROXY=1
# HTTPS_PROXY=http://代理地址:端口
